@{
    ViewBag.Title = "Início";
}

<style>
    .hero {
        background: linear-gradient(135deg, #042C53 0%, #185FA5 60%, #378ADD 100%);
        border-radius: 12px;
        padding: 48px 32px 40px;
        text-align: center;
        margin-bottom: 32px;
        position: relative;
        overflow: hidden;
    }

    .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.2);
        color: #B5D4F4;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 4px 14px;
        border-radius: 999px;
        margin-bottom: 16px;
    }

    .hero h1 {
        font-size: 36px;
        font-weight: 600;
        color: #fff;
        margin-bottom: 12px;
    }

    .hero p {
        font-size: 15px;
        color: #B5D4F4;
        max-width: 480px;
        margin: 0 auto;
        line-height: 1.7;
    }

    .nav-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .nav-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 28px 24px;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: border-color 0.15s, transform 0.15s;
    }

        .nav-card:hover {
            border-color: #378ADD;
            transform: translateY(-2px);
            text-decoration: none;
        }

    .card-icon {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .icon-blue {
        background: #E6F1FB;
    }

    .icon-teal {
        background: #E1F5EE;
    }

    .icon-amber {
        background: #FAEEDA;
    }

    .card-title {
        font-size: 15px;
        font-weight: 500;
        color: #111;
        margin: 0;
    }

    .card-desc {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.6;
        margin: 0;
    }

    .card-link {
        font-size: 12px;
        font-weight: 500;
        color: #378ADD;
        margin-top: 4px;
    }

    .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 24px;
    }

    .stat {
        background: #f9fafb;
        border-radius: 8px;
        padding: 16px;
        text-align: center;
    }

    .stat-num {
        font-size: 22px;
        font-weight: 500;
        color: #185FA5;
    }

    .stat-label {
        font-size: 12px;
        color: #6b7280;
        margin-top: 2px;
    }
</style>

<div class="hero">
    <span class="hero-badge">Sistema de Gestão</span>
    <h1>Papelaria Central</h1>
    <p>Gerencie seu estoque, acompanhe suas vendas e mantenha sua equipe organizada — tudo em um só lugar.</p>
</div>

<div class="nav-cards">
    <a class="nav-card" href="/Produto/Index">
        <div class="card-icon icon-blue">📦</div>
        <div>
            <p class="card-title">Produtos</p>
            <p class="card-desc">Controle seu estoque, cadastre novos itens e gerencie preços e quantidades.</p>
        </div>
        <span class="card-link">Ver produtos →</span>
    </a>
    <a class="nav-card" href="/Venda/Index">
        <div class="card-icon icon-teal">💰</div>
        <div>
            <p class="card-title">Vendas</p>
            <p class="card-desc">Registre e acompanhe todas as vendas realizadas com histórico completo.</p>
        </div>
        <span class="card-link">Ver vendas →</span>
    </a>
    <a class="nav-card" href="/Vendedor/Index">
        <div class="card-icon icon-amber">👨‍💼</div>
        <div>
            <p class="card-title">Vendedores</p>
            <p class="card-desc">Gerencie sua equipe de vendas, cadastre e acompanhe o desempenho.</p>
        </div>
        <span class="card-link">Ver vendedores →</span>
    </a>
</div>

<div class="stats">
    <div class="stat">
        <div class="stat-num">@ViewBag.TotalProdutos</div>
        <div class="stat-label">Produtos cadastrados</div>
    </div>
    <div class="stat">
        <div class="stat-num">@ViewBag.TotalVendas</div>
        <div class="stat-label">Vendas realizadas</div>
    </div>
    <div class="stat">
        <div class="stat-num">@ViewBag.TotalVendedores</div>
        <div class="stat-label">Vendedores ativos</div>
    </div>
</div>