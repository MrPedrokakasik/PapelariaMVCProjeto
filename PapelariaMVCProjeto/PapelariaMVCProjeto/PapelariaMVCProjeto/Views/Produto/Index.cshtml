@model IEnumerable<PapelariaMVCProjeto.Models.Produto>

<style>
    .produtos-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

        .produtos-header h2 {
            font-size: 22px;
            font-weight: 500;
        }

    .btn-novo {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background-color: #e8f0fe;
        color: #1a5fcc;
        border: 1px solid #c5d8fc;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
    }

    .card-table {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
    }

        .card-table table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        .card-table thead th {
            background: #f9fafb;
            padding: 12px 16px;
            text-align: left;
            font-size: 12px;
            font-weight: 500;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            border-bottom: 1px solid #e5e7eb;
        }

        .card-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
        }

            .card-table tbody tr:last-child {
                border-bottom: none;
            }

            .card-table tbody tr:hover {
                background: #f9fafb;
            }

        .card-table tbody td {
            padding: 13px 16px;
            vertical-align: middle;
        }

    .badge-qty {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 999px;
        font-size: 12px;
        background: #f3f4f6;
        color: #6b7280;
        border: 1px solid #e5e7eb;
    }

    .acoes {
        display: flex;
        gap: 4px;
    }

    .btn-acao {
        padding: 5px 10px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        border: 1px solid #e5e7eb;
        text-decoration: none;
        background: transparent;
    }

    .btn-editar {
        color: #1a5fcc;
    }

        .btn-editar:hover {
            background: #e8f0fe;
            border-color: #c5d8fc;
        }

    .btn-detalhes {
        color: #6b7280;
    }

        .btn-detalhes:hover {
            background: #f3f4f6;
        }

    .btn-excluir {
        color: #c0392b;
    }

        .btn-excluir:hover {
            background: #fdecea;
            border-color: #f5c6c2;
        }

    .produto-thumb {
        width: 44px;
        height: 44px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
    }

    .produto-thumb-vazio {
        width: 44px;
        height: 44px;
        border-radius: 6px;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .nome-row {
        display: flex;
        align-items: center;
        gap: 12px;
    }
</style>

<div class="produtos-header">
    <h2>Produtos</h2>
    @Html.ActionLink("+ Novo Produto", "Create", null, new { @class = "btn-novo" })
</div>

<div class="card-table">
    <table>
        <thead>
            <tr>
                <th>Nome</th>
                <th>Preço</th>
                <th>Quantidade</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="nome-row">
                            @if (!string.IsNullOrEmpty(item.Imagem))
                            {
                                <img src="/Content/Imagens/@item.Imagem" class="produto-thumb" alt="@item.Nome" />
                            }
                            else
                            {
                                <div class="produto-thumb-vazio">📦</div>
                            }
                            <span style="font-weight:500">@item.Nome</span>
                        </div>
                    </td>
                    <td>R$ @item.Preco</td>
                    <td><span class="badge-qty">@item.Quantidade</span></td>
                    <td>
                        <div class="acoes">
                            @Html.ActionLink("Editar", "Edit", new { id = item.Id }, new { @class = "btn-acao btn-editar" })
                            @Html.ActionLink("Detalhes", "Details", new { id = item.Id }, new { @class = "btn-acao btn-detalhes" })
                            @Html.ActionLink("Excluir", "Delete", new { id = item.Id }, new { @class = "btn-acao btn-excluir" })
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>