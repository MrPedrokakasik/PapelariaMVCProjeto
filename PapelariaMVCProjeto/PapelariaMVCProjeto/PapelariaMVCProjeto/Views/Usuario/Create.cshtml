@model PapelariaMVCProjeto.Models.Usuario

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 1rem 0 24px;
    }

    .back-btn {
        font-size: 13px;
        color: #6b7280;
        text-decoration: none;
        padding: 6px 10px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
    }

        .back-btn:hover {
            background: #f9fafb;
        }

    .page-title {
        font-size: 20px;
        font-weight: 500;
    }

    .form-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 28px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #6b7280;
        margin-bottom: 6px;
    }

    .form-control {
        width: 100%;
        padding: 9px 12px;
        font-size: 14px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        outline: none;
    }

        .form-control:focus {
            border-color: #185FA5;
            box-shadow: 0 0 0 3px rgba(24,95,165,0.12);
        }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid #e5e7eb;
    }

    .btn-cancelar {
        padding: 9px 20px;
        font-size: 14px;
        font-weight: 500;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background: transparent;
        color: #6b7280;
        text-decoration: none;
    }

        .btn-cancelar:hover {
            background: #f9fafb;
        }

    .btn-salvar {
        padding: 9px 24px;
        font-size: 14px;
        font-weight: 500;
        border: none;
        border-radius: 8px;
        background: #185FA5;
        color: #fff;
        cursor: pointer;
    }

        .btn-salvar:hover {
            background: #042C53;
        }

    .field-error {
        color: #E24B4A;
        font-size: 12px;
        margin-top: 4px;
    }

    .info-box {
        background: #E6F1FB;
        border: 1px solid #B5D4F4;
        border-radius: 8px;
        padding: 12px 14px;
        font-size: 13px;
        color: #0C447C;
        margin-bottom: 24px;
    }
</style>

<div class="page-header">
    @Html.ActionLink("← Voltar", "Index", null, new { @class = "back-btn" })
    <span class="page-title">Novo Usuário</span>
</div>

<div class="form-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="info-box">
            ℹ️ O usuário terá acesso completo ao sistema após o cadastro.
        </div>

        <div class="form-group">
            <label class="form-label">Login</label>
            @Html.TextBoxFor(m => m.Login, new { @class = "form-control", placeholder = "Ex: joao.silva" })
            @Html.ValidationMessageFor(m => m.Login, "", new { @class = "field-error" })
        </div>

        <div class="form-group">
            <label class="form-label">Senha</label>
            @Html.PasswordFor(m => m.Senha, new { @class = "form-control", placeholder = "••••••••" })
            @Html.ValidationMessageFor(m => m.Senha, "", new { @class = "field-error" })
        </div>

        <div class="form-footer">
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn-cancelar" })
            <button type="submit" class="btn-salvar">Salvar usuário</button>
        </div>
    }
</div>