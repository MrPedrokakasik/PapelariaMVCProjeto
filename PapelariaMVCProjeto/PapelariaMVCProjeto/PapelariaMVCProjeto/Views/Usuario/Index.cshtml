@model IEnumerable<PapelariaMVCProjeto.Models.Usuario>

<style>
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-top: 1rem;
    }

    .titulo {
        font-size: 22px;
        font-weight: 500;
    }

    .btn-novo {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border: 1px solid #B5D4F4;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #185FA5;
        background: #E6F1FB;
        text-decoration: none;
    }

    .card-table {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    thead th {
        background: #f9fafb;
        padding: 12px 16px;
        text-align: left;
        font-size: 12px;
        font-weight: 500;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid #e5e7eb;
    }

    tbody tr {
        border-bottom: 1px solid #f3f4f6;
    }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody tr:hover {
            background: #f9fafb;
        }

    tbody td {
        padding: 13px 16px;
        vertical-align: middle;
    }

    .avatar-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .avatar-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #E6F1FB;
        color: #185FA5;
        font-size: 12px;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .usuario-login {
        font-weight: 500;
    }

    .btn-excluir-row {
        font-size: 12px;
        font-weight: 500;
        color: #E24B4A;
        text-decoration: none;
        padding: 5px 10px;
        border: 1px solid #F09595;
        border-radius: 8px;
    }

        .btn-excluir-row:hover {
            background: #FCEBEB;
        }
</style>

<div class="header">
    <span class="titulo">Usuários</span>
    @Html.ActionLink("+ Novo Usuário", "Create", null, new { @class = "btn-novo" })
</div>

<div class="card-table">
    <table>
        <thead>
            <tr>
                <th>Usuário</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var iniciais = item.Login.Length >= 2
                    ? item.Login.Substring(0, 2).ToUpper()
                    : item.Login.Substring(0, 1).ToUpper();
                <tr>
                    <td>
                        <div class="avatar-row">
                            <div class="avatar-circle">@iniciais</div>
                            <span class="usuario-login">@item.Login</span>
                        </div>
                    </td>
                    <td style="text-align: right;">
                        @Html.ActionLink("Excluir", "Delete", new { id = item.Id }, new { @class = "btn-excluir-row" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>