@{
    ViewBag.Title = "Contato";
}

<style>
    .page-header {
        margin: 1rem 0 28px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 500;
    }

    .form-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 28px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #6b7280;
        margin-bottom: 6px;
    }

    .form-control {
        width: 100%;
        padding: 9px 12px;
        font-size: 14px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background: #fff;
        outline: none;
    }

        .form-control:focus {
            border-color: #185FA5;
            box-shadow: 0 0 0 3px rgba(24,95,165,0.12);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid #e5e7eb;
    }

    .btn-enviar {
        padding: 9px 24px;
        font-size: 14px;
        font-weight: 500;
        border: none;
        border-radius: 8px;
        background: #185FA5;
        color: #fff;
        cursor: pointer;
    }

        .btn-enviar:hover {
            background: #042C53;
        }

    .info-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 24px;
    }

    .info-card {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
        text-align: center;
    }

    .info-icon {
        font-size: 20px;
        margin-bottom: 6px;
    }

    .info-title {
        font-size: 12px;
        font-weight: 500;
        color: #6b7280;
        margin-bottom: 4px;
    }

    .info-value {
        font-size: 13px;
        color: #111;
        font-weight: 500;
    }
</style>

<div class="page-header">
    <span class="page-title">Contato</span>
</div>

<div class="info-row">
    <div class="info-card">
        <div class="info-icon">📧</div>
        <div class="info-title">E-mail</div>
        <div class="info-value">contato@papelariacentral.com</div>
    </div>
    <div class="info-card">
        <div class="info-icon">📞</div>
        <div class="info-title">Telefone</div>
        <div class="info-value">(18) 7070-7070</div>
    </div>
    <div class="info-card">
        <div class="info-icon">📍</div>
        <div class="info-title">Rua das Pinóias, 70</div>
        <div class="info-value">São Paulo, SP</div>
    </div>
</div>

<div class="form-card">
    <div class="form-group">
        <label class="form-label">Nome</label>
        <input class="form-control" type="text" placeholder="Seu nome completo" />
    </div>
    <div class="form-group">
        <label class="form-label">E-mail</label>
        <input class="form-control" type="email" placeholder="seu@email.com" />
    </div>
    <div class="form-group">
        <label class="form-label">Mensagem</label>
        <textarea class="form-control" placeholder="Como podemos ajudar?"></textarea>
    </div>
    <div class="form-footer">
        <button class="btn-enviar" type="submit">Enviar mensagem</button>
    </div>
</div>