@model PapelariaMVCProjeto.Models.Produto

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 1rem 0 24px;
    }

    .back-btn {
        font-size: 13px;
        color: #6b7280;
        text-decoration: none;
        padding: 6px 10px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
    }

        .back-btn:hover {
            background: #f9fafb;
        }

    .page-title {
        font-size: 20px;
        font-weight: 500;
    }

    .alert-card {
        background: #fff;
        border: 1px solid #F09595;
        border-radius: 12px;
        padding: 28px;
    }

    .alert-icon {
        width: 48px;
        height: 48px;
        background: #FCEBEB;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        margin-bottom: 16px;
    }

    .alert-title {
        font-size: 17px;
        font-weight: 500;
        margin-bottom: 6px;
    }

    .alert-desc {
        font-size: 14px;
        color: #6b7280;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .produto-info {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
    }

    .produto-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #E24B4A;
        flex-shrink: 0;
    }

    .produto-nome {
        font-size: 14px;
        font-weight: 500;
    }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding-top: 20px;
        border-top: 1px solid #e5e7eb;
    }

    .btn-cancelar {
        padding: 9px 20px;
        font-size: 14px;
        font-weight: 500;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background: transparent;
        color: #6b7280;
        text-decoration: none;
    }

        .btn-cancelar:hover {
            background: #f9fafb;
        }

    .btn-excluir {
        padding: 9px 24px;
        font-size: 14px;
        font-weight: 500;
        border: none;
        border-radius: 8px;
        background: #E24B4A;
        color: #fff;
        cursor: pointer;
    }

        .btn-excluir:hover {
            background: #A32D2D;
        }
</style>

<div class="page-header">
    @Html.ActionLink("← Voltar", "Index", null, new { @class = "back-btn" })
    <span class="page-title">Excluir Produto</span>
</div>

<div class="alert-card">
    <div class="alert-icon">⚠️</div>
    <p class="alert-title">Confirmar exclusão</p>
    <p class="alert-desc">Esta ação é permanente e não poderá ser desfeita. O produto será removido do sistema.</p>

    <div class="produto-info">
        <div class="produto-dot"></div>
        <span class="produto-nome">@Model.Nome</span>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="form-footer">
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn-cancelar" })
            <button type="submit" class="btn-excluir">Sim, excluir</button>
        </div>
    }
</div>