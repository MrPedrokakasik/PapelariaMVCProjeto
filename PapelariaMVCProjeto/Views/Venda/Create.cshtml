@model PapelariaMVCProjeto.Models.Venda

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 1rem 0 24px;
    }

    .back-btn {
        font-size: 13px;
        color: #6b7280;
        text-decoration: none;
        padding: 6px 10px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
    }

        .back-btn:hover {
            background: #f9fafb;
        }

    .page-title {
        font-size: 20px;
        font-weight: 500;
    }

    .form-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 28px;
    }

    .section-label {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #6b7280;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 1px solid #e5e7eb;
    }

    .info-box {
        background: #E1F5EE;
        border: 1px solid #9FE1CB;
        border-radius: 8px;
        padding: 12px 14px;
        font-size: 13px;
        color: #085041;
        margin-bottom: 24px;
    }

    .erro-box {
        background: #FCEBEB;
        border: 1px solid #F09595;
        border-radius: 8px;
        padding: 12px 14px;
        font-size: 13px;
        color: #A32D2D;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #6b7280;
        margin-bottom: 6px;
    }

    .form-control {
        width: 100%;
        padding: 9px 12px;
        font-size: 14px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background: #fff;
    }

        .form-control:focus {
            border-color: #1D9E75;
            box-shadow: 0 0 0 3px rgba(29,158,117,0.12);
            outline: none;
        }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .qty-hint {
        font-size: 12px;
        color: #6b7280;
        margin-top: 5px;
    }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid #e5e7eb;
    }

    .btn-cancelar {
        padding: 9px 20px;
        font-size: 14px;
        font-weight: 500;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background: transparent;
        color: #6b7280;
        text-decoration: none;
    }

        .btn-cancelar:hover {
            background: #f9fafb;
        }

    .btn-vender {
        padding: 9px 24px;
        font-size: 14px;
        font-weight: 500;
        border: none;
        border-radius: 8px;
        background: #0F6E56;
        color: #fff;
        cursor: pointer;
    }

        .btn-vender:hover {
            background: #085041;
        }

    .field-error {
        color: #E24B4A;
        font-size: 12px;
        margin-top: 4px;
    }
</style>

<div class="page-header">
    @Html.ActionLink("← Voltar", "Index", null, new { @class = "back-btn" })
    <span class="page-title">Nova Venda</span>
</div>

<div class="form-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <p class="section-label">Detalhes da venda</p>

        if (!ViewData.ModelState.IsValid)
        {
            <div class="erro-box">
                ⚠️
                @foreach (var erro in ViewData.ModelState.Values)
                {
                    foreach (var msg in erro.Errors)
                    {
                        <span>@msg.ErrorMessage</span>
                    }
                }
            </div>
        }

        <div class="info-box">
            💡 O total será calculado automaticamente com base no preço do produto.
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Produto</label>
                @Html.DropDownList("ProdutoId", null, "-- Selecione --", new { @class = "form-control" })
                @Html.ValidationMessage("ProdutoId", "", new { @class = "field-error" })
            </div>
            <div class="form-group">
                <label class="form-label">Vendedor</label>
                @Html.DropDownList("VendedorId", null, "-- Selecione --", new { @class = "form-control" })
                @Html.ValidationMessage("VendedorId", "", new { @class = "field-error" })
            </div>
        </div>

        <div class="form-group" style="max-width: 200px;">
            <label class="form-label">Quantidade</label>
            @Html.EditorFor(m => m.Quantidade, new { htmlAttributes = new { @class = "form-control", min = "1" } })
            <p class="qty-hint">O estoque será atualizado automaticamente.</p>
            @Html.ValidationMessageFor(m => m.Quantidade, "", new { @class = "field-error" })
        </div>

        <div class="form-footer">
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn-cancelar" })
            <button type="submit" class="btn-vender">Realizar venda</button>
        </div>
    }
</div>